{
  "name": "testpilot",
  "version": "0.1.0",
  "description": "AI-powered test case generation CLI — generates Playwright TypeScript tests from requirements docs, OpenAPI specs, or text descriptions",
  "type": "module",
  "bin": {
    "testpilot": "./dist/bin/testpilot.js"
  },
  "scripts": {
    "dev": "tsx bin/testpilot.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ test/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "testing",
    "playwright",
    "ai",
    "test-generation",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@apidevtools/swagger-parser": "^12.1.0",
    "@inquirer/prompts": "^8.4.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "cosmiconfig": "^9.0.1",
    "inquirer": "^13.4.2",
    "marked": "^18.0.2",
    "openai": "^6.34.0",
    "ora": "^9.4.0",
    "prettier": "^3.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/node": "^25.6.0",
    "@types/swagger-schema-official": "^2.0.25",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
